{% comment %}
  login / contents 用共通 head
  pathPrefix 設定時は pathPrefix/assets/、未設定時は ../assets/
{% endcomment %}
{% if pathPrefix != '' and pathPrefix != null %}
  {% assign login_asset_base = pathPrefix | append: '/' %}
{% else %}
  {% assign login_asset_base = '../' %}
{% endif %}
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
<meta name="format-detection" content="telephone=no">
<meta name="description" content="主婦に嬉しい食品・日用品がもらえる・ためせるお試しサイト！お得に商品が試せて、更にシェアフルポイントを貯めることもできます。">
<meta name="keywords" content="シェアフルモニター,シェアフルポイント,プレゼント,試供品,無料,サンプリング">

<title>{{ page_title }}</title>

<link rel="stylesheet" href="{{ login_asset_base }}assets/vendor/fontawesome/css/all.css">
<link rel="stylesheet" href="{{ login_asset_base }}assets/css/reset.css">
