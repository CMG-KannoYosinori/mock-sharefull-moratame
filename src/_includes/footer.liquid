{% comment %}
  ページの階層に応じてマイメニューリンクの相対パスを算出
  page.url: / または /contents/signup01.html など（.html フラット出力）
{% endcomment %}
{% if page.url contains 'mymenu' %}
  {% assign mymenu_href = '' %}
{% else %}
  {% assign path_segments = page.url | split: '/' %}
  {% assign seg_count = path_segments | size %}
  {% assign depth = seg_count | minus: 1 %}
  {% if depth < 0 %}
    {% assign depth = 0 %}
  {% endif %}
  {% if depth == 0 %}
    {% assign mymenu_href = 'mymenu/basic.html' %}
  {% elsif depth == 1 %}
    {% assign mymenu_href = '../mymenu/basic.html' %}
  {% else %}
    {% assign mymenu_href = '../../mymenu/basic.html' %}
  {% endif %}
{% endif %}

