{% comment %}
  共通 head ブロック
  pathPrefix が設定されているとき（GitHub Pages デプロイ時）は常に pathPrefix/ をアセットの先頭に付与
{% endcomment %}
{% if pathPrefix != '' and pathPrefix != null %}
  {% assign asset_base = pathPrefix | append: '/' %}
{% elsif page.url contains 'mymenu' %}
  {% assign asset_base = '../' %}
{% else %}
  {% assign path_segments = page.url | split: '/' %}
  {% assign seg_count = path_segments | size %}
  {% assign depth = seg_count | minus: 1 %}
  {% if depth < 0 %}
    {% assign depth = 0 %}
  {% endif %}
  {% if depth == 0 %}
    {% assign asset_base = '' %}
  {% elsif depth == 1 %}
    {% assign asset_base = '../' %}
  {% else %}
    {% assign asset_base = '../../' %}
  {% endif %}
{% endif %}
{% unless page_description %}
  {% assign page_description = '主婦に嬉しい食品・日用品がもらえる・ためせるお試しサイト！お得に商品が試せて、更にシェアフルポイントを貯めることもできます。' %}
{% endunless %}

