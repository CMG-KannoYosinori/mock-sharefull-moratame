{% comment %}
  共通 head ブロック
  - 通常ページ用（既存の head）
  - ログイン / contents 用（旧 head-login-contents）
  pathPrefix が設定されているとき（GitHub Pages デプロイ時）は常に pathPrefix/ をアセットの先頭に付与
{% endcomment %}
{% if page_is_login_contents %}
  {% if pathPrefix != '' and pathPrefix != null %}
    {% assign asset_base = pathPrefix | append: '/' %}
  {% else %}
    {% assign asset_base = '../' %}
  {% endif %}
{% else %}
  {% if pathPrefix != '' and pathPrefix != null %}
    {% assign asset_base = pathPrefix | append: '/' %}
  {% elsif page.url contains 'mymenu' %}
    {% assign asset_base = '../' %}
  {% elsif page.url contains 'detail' %}
    {%- assign asset_base = '../' -%}
  {% elsif page.url contains 'contents' or page.url contains 'login' %}
    {% assign asset_base = '../' %}
  {% else %}
    {% assign path_segments = page.url | split: '/' %}
    {% assign seg_count = path_segments | size %}
    {% assign depth = seg_count | minus: 1 %}
    {% if depth < 0 %}
      {% assign depth = 0 %}
    {% endif %}
    {% if depth == 0 %}
      {% assign asset_base = '' %}
    {% elsif depth == 1 %}
      {% assign asset_base = '../' %}
    {% else %}
      {% assign asset_base = '../../' %}
    {% endif %}
  {% endif %}
{% endif %}

<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="format-detection" content="telephone=no">
<meta name="description" content="主婦に嬉しい食品・日用品がもらえる・ためせるお試しサイト！お得に商品が試せて、更にシェアフルポイントを貯めることもできます。">
<meta name="keywords" content="シェアフルモニター,シェアフルポイント,プレゼント,試供品,無料,サンプリング">

<title>{{ page_title }}</title>

<link rel="stylesheet" href="{{ asset_base }}assets/css/style.css">
<link rel="stylesheet" href="{{ asset_base }}assets/vendor/fontawesome/css/all.css">
{{ head_extra }}
<link rel="stylesheet" href="{{ asset_base }}assets/css/utilities.css">
<script src="{{ asset_base }}assets/vendor/jquery/jquery-3.2.1.min.js"></script>
{% if page_is_login_contents %}
  <script src="{{ asset_base }}assets/js/inputimg.js"></script>
{% endif %}
