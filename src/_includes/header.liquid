    <!-- topTabMenu_pc -->
    {% assign nav_top_active = '' %}
    {% assign nav_tame_active = '' %}
    {% assign nav_mora_active = '' %}
    {% assign nav_mise_active = '' %}
    {%- case page.url -%}
      {%- when '/' -%}
        {% assign nav_top_active = ' is-active' %}
      {%- when '/index.html' -%}
        {% assign nav_top_active = ' is-active' %}
      {%- when '/detail/tamesulist.html' -%}
        {% assign nav_tame_active = ' is-active' %}
      {%- when '/detail/moraulist.html' -%}
        {% assign nav_mora_active = ' is-active' %}
      {%- when '/mymenu/basic.html' -%}
        {% assign nav_mise_active = ' is-active' %}
    {%- endcase -%}
    <nav aria-label="トップページタブメニュー" class="h-full">
      <ul class="p-masthead__nav">
        <li class=" p-masthead__nav__top{{ nav_top_active }}">
          <a href="{{ top_href }}" class="p-masthead__nav-item{{ nav_top_active }}">トップ</a>
        </li>
        <li class=" p-masthead__nav__tame{{ nav_tame_active }}">
          <a href="{{ tamesu_href }}" class="p-masthead__nav-item{{ nav_tame_active }}">ためせる</a>
        </li>
        <li class="p-masthead__nav__mora{{ nav_mora_active }}">
          <a href="{{ morau_href }}" class="p-masthead__nav-item{{ nav_mora_active }}">もらえる</a>
        </li>
        <li class="p-masthead__nav__mise{{ nav_mise_active }}">
          <a href="{{ mymenu_href }}" class="p-masthead__nav-item{{ nav_mise_active }}">マイメニュー</a>
        </li>
      </ul>
    </nav>
    <!-- /topTabMenu_pc -->
  </div>

  <!-- accordion-menu -->
  <script>
    $(function () {
      $('#menu .js-menu__link').each(function () {
        $(this).on('click', function () {
          $(this).toggleClass('on');
          // 連打でアニメーションがキューに積み上がるのを防ぐ（終端状態へのジャンプはしない）
          $('+.submenu', this).stop(true, false).slideToggle();
          return false;
        });
      });
    });
  </script>
  <!-- /accordion-menu -->
