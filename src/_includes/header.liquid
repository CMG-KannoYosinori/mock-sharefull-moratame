{% comment %}
  ページの階層に応じてリンク・asset_base を算出。pathPrefix 設定時（GitHub
  Pages）はサブパス付き絶対パスを使用。
{% endcomment %}
{% if pathPrefix != '' and pathPrefix != null %}
  {% assign asset_base = pathPrefix | append: '/' %}
  {% assign mymenu_href = pathPrefix | append: '/mymenu/basic.html' %}
  {% assign top_href = pathPrefix | append: '/index.html' %}
  {% assign tamesu_href = pathPrefix | append: '/detail/tamesulist.html' %}
  {% assign morau_href = pathPrefix | append: '/detail/moraulist.html' %}
  {% assign trade_href = pathPrefix | append: '/contents/trade/index.html' %}
{% elsif page.url contains 'mymenu' %}
  {% assign mymenu_href = 'basic.html' %}
  {% assign asset_base = '../' %}
  {% assign top_href = '../index.html' %}
  {% assign tamesu_href = '../detail/tamesulist.html' %}
  {% assign morau_href = '../detail/moraulist.html' %}
  {% assign trade_href = '../contents/trade/index.html' %}
{% else %}
  {% assign path_segments = page.url | split: '/' %}
  {% assign seg_count = path_segments | size %}
  {% assign depth = seg_count | minus: 1 %}
  {% if depth < 0 %} {% assign depth = 0 %} {% endif %}
  {% if depth == 0 %}
    {% assign mymenu_href = 'mymenu/basic.html' %}
    {% assign asset_base = '' %}
    {% assign top_href = 'index.html' %}
    {% assign tamesu_href = 'detail/tamesulist.html' %}
    {% assign morau_href = 'detail/moraulist.html' %}
    {% assign trade_href = 'contents/trade/index.html' %}
  {% elsif depth == 1 %}
    {% assign mymenu_href = '../mymenu/basic.html' %}
    {% assign asset_base = '../' %}
    {% assign top_href = '../index.html' %}
    {% if page.url contains 'detail' %}
      {% assign tamesu_href = 'tamesulist.html' %}
      {% assign morau_href = 'moraulist.html' %}
      {% assign trade_href = '../contents/trade/index.html' %}
    {% else %}
      {% assign tamesu_href = '../detail/tamesulist.html' %}
      {% assign morau_href = '../detail/moraulist.html' %}
      {% assign trade_href = 'trade/index.html' %}
    {% endif %}
  {% else %}
    {% assign mymenu_href = '../../mymenu/basic.html' %}
    {% assign asset_base = '../../' %}
    {% assign top_href = '../../index.html' %}
    {% if page.url contains 'detail' %}
      {% assign tamesu_href = '../detail/tamesulist.html' %}
      {% assign morau_href = '../detail/moraulist.html' %}
      {% assign trade_href = '../../contents/trade/index.html' %}
    {% else %}
      {% assign tamesu_href = '../detail/tamesulist.html' %}
      {% assign morau_href = '../detail/moraulist.html' %}
      {% assign trade_href = '../trade/index.html' %}
    {% endif %}
  {% endif %}
{% endif %}

